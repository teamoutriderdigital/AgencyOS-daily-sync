# Supabase project credentials (Project Settings → API).
# The anon key is used by both the browser and the server. RLS on the daily/
# l10 tables is permissive (internal tool) — protect access at the deployment
# layer (e.g. Vercel password protection or a private network).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
